<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.calendar.CleaningCalendarController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="%role.firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="%nav.dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.upratovania" onAction="#navCalendar" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="%nav.zakaznici" onAction="#navCustomers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.apartmany" onAction="#navApartments" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.zamestnanci" onAction="#navEmployees" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.statistiky" onAction="#navStatistics" styleClass="nav-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="4">
                <Button text="SK" onAction="#onLangSk" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="EN" onAction="#onLangEn" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <Button text="%nav.odhlasit" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="16">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label text="%calendar.title" styleClass="page-title"/>
                    <Label text="%calendar.subtitle" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="%calendar.add" onAction="#onAdd" styleClass="primary-button"/>
            </HBox>

            <HBox spacing="12" styleClass="filter-bar" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="%calendar.filter.employee" styleClass="field-label"/>
                    <ComboBox fx:id="employeeCombo" prefWidth="200" styleClass="input"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="%calendar.filter.status" styleClass="field-label"/>
                    <ComboBox fx:id="statusCombo" prefWidth="160" styleClass="input"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="4" alignment="CENTER_RIGHT">
                    <Label fx:id="resultsCountLabel" text="0" styleClass="page-subtitle"/>
                    <Button text="%btn.clear.filters" onAction="#onClearFilters" styleClass="secondary-button"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="calendar-controls">
                <Button text="◄" onAction="#onPrev" styleClass="calendar-nav-button"/>
                <Button text="%calendar.today" onAction="#onToday" styleClass="secondary-button"/>
                <Button text="►" onAction="#onNext" styleClass="calendar-nav-button"/>
                <Label fx:id="dateRangeLabel" text="" styleClass="calendar-range-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="view-toggle" alignment="CENTER">
                    <ToggleButton fx:id="dayToggle" text="%calendar.view.day" styleClass="view-toggle-button"/>
                    <ToggleButton fx:id="weekToggle" text="%calendar.view.week" styleClass="view-toggle-button"/>
                    <ToggleButton fx:id="monthToggle" text="%calendar.view.month" styleClass="view-toggle-button"/>
                </HBox>
            </HBox>

            <StackPane fx:id="calendarHolder" VBox.vgrow="ALWAYS" styleClass="calendar-holder"/>
        </VBox>
    </center>
</BorderPane>
