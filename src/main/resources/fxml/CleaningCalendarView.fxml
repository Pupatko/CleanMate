<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.calendar.CleaningCalendarController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="Firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="Dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Upratovania" onAction="#navCalendar" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="Zákazníci" onAction="#navCustomers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Apartmány" onAction="#navApartments" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zamestnanci" onAction="#navEmployees" styleClass="nav-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Odhlásiť" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="16">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label text="Upratovania" styleClass="page-title"/>
                    <Label text="Kalendárny prehľad upratovaní apartmánov" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Pridať upratovanie" onAction="#onAdd" styleClass="primary-button"/>
            </HBox>

            <HBox spacing="12" styleClass="filter-bar" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Zamestnanec" styleClass="field-label"/>
                    <ComboBox fx:id="employeeCombo" prefWidth="200" styleClass="input"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Stav" styleClass="field-label"/>
                    <ComboBox fx:id="statusCombo" prefWidth="160" styleClass="input"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="4" alignment="CENTER_RIGHT">
                    <Label fx:id="resultsCountLabel" text="Upratovaní: 0" styleClass="page-subtitle"/>
                    <Button text="Vymazať filtre" onAction="#onClearFilters" styleClass="secondary-button"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="calendar-controls">
                <Button text="◄" onAction="#onPrev" styleClass="calendar-nav-button"/>
                <Button text="Dnes" onAction="#onToday" styleClass="secondary-button"/>
                <Button text="►" onAction="#onNext" styleClass="calendar-nav-button"/>
                <Label fx:id="dateRangeLabel" text="" styleClass="calendar-range-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="view-toggle" alignment="CENTER">
                    <ToggleButton fx:id="dayToggle" text="Deň" styleClass="view-toggle-button"/>
                    <ToggleButton fx:id="weekToggle" text="Týždeň" styleClass="view-toggle-button"/>
                    <ToggleButton fx:id="monthToggle" text="Mesiac" styleClass="view-toggle-button"/>
                </HBox>
            </HBox>

            <StackPane fx:id="calendarHolder" VBox.vgrow="ALWAYS" styleClass="calendar-holder"/>
        </VBox>
    </center>
</BorderPane>
