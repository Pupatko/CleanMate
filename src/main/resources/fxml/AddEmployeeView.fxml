<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.employee.AddEmployeeController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="Firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="Dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Upratovania" onAction="#navCalendar" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zákazníci" onAction="#navCustomers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Apartmány" onAction="#navApartments" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zamestnanci" onAction="#navEmployees" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Odhlásiť" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="20">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label fx:id="pageTitle" text="Nový zamestnanec" styleClass="page-title"/>
                    <Label fx:id="pageSubtitle" text="Vyplňte informácie o novom členovi tímu" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Späť" onAction="#onBack" styleClass="secondary-button"/>
            </HBox>

            <VBox spacing="20" styleClass="form-card" VBox.vgrow="ALWAYS">
                <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

                <Label text="Osobné informácie" styleClass="section-title"/>

                <GridPane hgap="20" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Meno" styleClass="field-label"/>
                        <TextField fx:id="firstNameField" styleClass="input" promptText="napr. Anna"/>
                    </VBox>
                    <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Priezvisko" styleClass="field-label"/>
                        <TextField fx:id="lastNameField" styleClass="input" promptText="napr. Nová"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="Email" styleClass="field-label"/>
                        <TextField fx:id="emailField" styleClass="input" promptText="anna.nova@firma.sk"/>
                    </VBox>
                    <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="Telefón" styleClass="field-label"/>
                        <TextField fx:id="phoneField" styleClass="input" promptText="+421 9XX XXX XXX"/>
                    </VBox>
                </GridPane>

                <Label text="Pracovné zaradenie" styleClass="section-title"/>

                <GridPane hgap="20" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Rola" styleClass="field-label"/>
                        <ComboBox fx:id="roleCombo" maxWidth="Infinity" styleClass="input"/>
                    </VBox>
                    <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Dátum nástupu" styleClass="field-label"/>
                        <TextField fx:id="startDateField" styleClass="input" promptText="DD.MM.YYYY"/>
                    </VBox>

                    <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1"
                          GridPane.columnSpan="2">
                        <Label text="Adresa bydliska" styleClass="field-label"/>
                        <TextField fx:id="addressField" styleClass="input" promptText="Ulica č., Mesto"/>
                    </VBox>
                </GridPane>

                <VBox spacing="4">
                    <Label text="Poznámky" styleClass="field-label"/>
                    <TextArea fx:id="notesArea" styleClass="input" promptText="Ďalšie poznámky..."
                              prefRowCount="3" wrapText="true"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Label fx:id="errorLabel" text="" styleClass="error-label"/>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Zrušiť" onAction="#onBack" styleClass="secondary-button"/>
                    <Button fx:id="saveButton" text="Uložiť zamestnanca" onAction="#onSave" styleClass="primary-button"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
