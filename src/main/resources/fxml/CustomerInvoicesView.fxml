<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.customer.CustomerInvoicesController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="%role.firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="%nav.dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.upratovania" onAction="#navCalendar" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.zakaznici" onAction="#navCustomers" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="%nav.apartmany" onAction="#navApartments" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.zamestnanci" onAction="#navEmployees" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.statistiky" onAction="#navStatistics" styleClass="nav-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="4">
                <Button text="SK" onAction="#onLangSk" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="EN" onAction="#onLangEn" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <Button text="%nav.odhlasit" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="16">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label fx:id="pageTitle" text="%invoices.owner.title" styleClass="page-title"/>
                    <Label fx:id="pageSubtitle" text="%invoices.owner.subtitle" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="%btn.back" onAction="#onBack" styleClass="secondary-button"/>
            </HBox>

            <HBox spacing="12" styleClass="filter-bar" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="%invoices.filter.apartment" styleClass="field-label"/>
                    <ComboBox fx:id="apartmentCombo" prefWidth="240" styleClass="input"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="%invoices.filter.period" styleClass="field-label"/>
                    <ComboBox fx:id="periodCombo" prefWidth="200" styleClass="input"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="%invoices.btn.generate" onAction="#onGenerateInvoice" styleClass="primary-button"/>
            </HBox>

            <HBox spacing="14">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="%invoices.stat.total" styleClass="stat-label"/>
                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="%invoices.stat.done" styleClass="stat-label"/>
                    <Label fx:id="statDone" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="%invoices.stat.hours" styleClass="stat-label"/>
                    <Label fx:id="statHours" text="0 h" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="%invoices.stat.revenue" styleClass="stat-label"/>
                    <Label fx:id="statRevenue" text="0 €" styleClass="stat-value stat-revenue"/>
                </VBox>
            </HBox>

            <HBox spacing="14" VBox.vgrow="ALWAYS">

                <VBox styleClass="form-card" HBox.hgrow="ALWAYS" spacing="8" prefWidth="600">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="%invoices.chart.title" styleClass="section-title"/>
                    <BarChart fx:id="monthlyChart" VBox.vgrow="ALWAYS" legendVisible="false"
                              animated="false" prefHeight="280">
                        <xAxis><CategoryAxis label="%invoices.chart.xaxis"/></xAxis>
                        <yAxis><NumberAxis label="%invoices.chart.yaxis"/></yAxis>
                    </BarChart>
                </VBox>

                <VBox styleClass="form-card" HBox.hgrow="ALWAYS" spacing="8" prefWidth="560">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="%invoices.table.title" styleClass="section-title"/>
                    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="colDate"     text="%col.invoice.date"     prefWidth="100"/>
                            <TableColumn fx:id="colProperty" text="%col.invoice.property" prefWidth="200"/>
                            <TableColumn fx:id="colHours"    text="%col.invoice.hours"    prefWidth="80"/>
                            <TableColumn fx:id="colStatus"   text="%col.invoice.status"   prefWidth="100"/>
                            <TableColumn fx:id="colPrice"    text="%col.invoice.price"    prefWidth="80"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
