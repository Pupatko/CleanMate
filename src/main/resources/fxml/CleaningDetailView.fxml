<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.detail.CleaningDetailController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="Firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="Dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Cleaning Calendar" onAction="#navCalendar" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="Zákazníci" onAction="#navCustomers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Cleaning Plány" onAction="#navPlans" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zamestnanci" onAction="#navEmployees" styleClass="nav-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Odhlásiť" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="20">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Detail upratovania" styleClass="page-title"/>
                    <Label text="Kompletné informácie a priebeh" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusBadge" text="NEW" styleClass="status-badge, status-new"/>
            </HBox>

            <GridPane hgap="16" vgap="10" styleClass="form-card">
                <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints percentWidth="50"/>
                    <javafx.scene.layout.ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Apartmán (Property)" styleClass="field-label"/>
                    <TextField fx:id="propertyField" styleClass="input"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Zákazník (Customer)" styleClass="field-label"/>
                    <TextField fx:id="customerField" styleClass="input"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Zamestnanec" styleClass="field-label"/>
                    <ComboBox fx:id="employeeCombo" styleClass="input" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Stav" styleClass="field-label"/>
                    <ComboBox fx:id="statusCombo" styleClass="input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                    <Label text="Dátum a čas" styleClass="field-label"/>
                    <TextField fx:id="dateField" styleClass="input"/>
                </VBox>
            </GridPane>

            <TabPane VBox.vgrow="ALWAYS" styleClass="detail-tabs">
                <tabs>
                    <Tab text="Checklist" closable="false">
                        <VBox spacing="10" styleClass="tab-body">
                            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Kroky upratovania" styleClass="section-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="progressLabel" text="Dokončené: 0 / 0" styleClass="page-subtitle"/>
                            </HBox>
                            <ListView fx:id="checklistView" VBox.vgrow="ALWAYS" styleClass="data-table"/>
                        </VBox>
                    </Tab>
                    <Tab text="Fotografie" closable="false">
                        <VBox spacing="10" styleClass="tab-body">
                            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Foto-dokumentácia" styleClass="section-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Pridať fotku" onAction="#onAddPhoto" styleClass="secondary-button"/>
                            </HBox>
                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="photo-scroll">
                                <GridPane fx:id="photoGrid" hgap="12" vgap="12">
                                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                                </GridPane>
                            </ScrollPane>
                        </VBox>
                    </Tab>
                </tabs>
            </TabPane>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Zrušiť upratovanie" onAction="#onCancel" styleClass="danger-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Priradiť" onAction="#onAssign" styleClass="secondary-button"/>
                <Button text="Uložiť" onAction="#onSave" styleClass="primary-button"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
