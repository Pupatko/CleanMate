<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.dashboard.DashboardController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>

            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="Firma" styleClass="sidebar-subtitle"/>

            <Region prefHeight="20"/>

            <Button text="Dashboard" onAction="#navDashboard" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="Upratovania" onAction="#navCalendar" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zákazníci" onAction="#navCustomers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Apartmány" onAction="#navApartments" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zamestnanci" onAction="#navEmployees" styleClass="nav-button" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Odhlásiť" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="20">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <VBox spacing="4">
                <Label text="Dashboard" styleClass="page-title"/>
                <Label text="Prehľad operácií na dnes" styleClass="page-subtitle"/>
            </VBox>

            <HBox spacing="16" styleClass="cards-row">
                <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="todayCountLabel" text="0" styleClass="card-value"/>
                    <Label text="Dnešné upratovania" styleClass="card-label"/>
                </VBox>
                <VBox styleClass="summary-card, card-warning" HBox.hgrow="ALWAYS">
                    <Label fx:id="unassignedCountLabel" text="0" styleClass="card-value"/>
                    <Label text="Nepriradené" styleClass="card-label"/>
                </VBox>
                <VBox styleClass="summary-card, card-info" HBox.hgrow="ALWAYS">
                    <Label fx:id="onDutyCountLabel" text="0" styleClass="card-value"/>
                    <Label text="Zamestnanci on-duty" styleClass="card-label"/>
                </VBox>
                <VBox styleClass="summary-card, card-success" HBox.hgrow="ALWAYS">
                    <Label fx:id="doneCountLabel" text="0" styleClass="card-value"/>
                    <Label text="Dokončené" styleClass="card-label"/>
                </VBox>
            </HBox>

            <Label text="Posledných 5 upratovaní" styleClass="section-title"/>

            <TableView fx:id="recentTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colTime" text="Čas" prefWidth="100"/>
                    <TableColumn fx:id="colProperty" text="Apartmán" prefWidth="320"/>
                    <TableColumn fx:id="colEmployee" text="Zamestnanec" prefWidth="220"/>
                    <TableColumn fx:id="colStatus" text="Stav" prefWidth="160"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
