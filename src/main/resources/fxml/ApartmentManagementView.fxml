<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.apartment.ApartmentManagementController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="Firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="Dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Upratovania" onAction="#navCalendar" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zákazníci" onAction="#navCustomers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Apartmány" onAction="#navApartments" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="Zamestnanci" onAction="#navEmployees" styleClass="nav-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Odhlásiť" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="20">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label text="Apartmány" styleClass="page-title"/>
                    <Label text="Správa apartmánov a cleaning plánov" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Pridať apartmán" onAction="#onAdd" styleClass="primary-button"/>
            </HBox>

            <HBox spacing="12" styleClass="filter-bar" alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Vyhľadávanie (adresa, zákazník)" styleClass="field-label"/>
                    <TextField fx:id="searchField" promptText="napr. Panská, Acme..." styleClass="input"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="4" alignment="CENTER_RIGHT">
                    <Label fx:id="countLabel" text="Apartmánov: 0" styleClass="page-subtitle"/>
                </VBox>
            </HBox>

            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="colAddress"  text="Adresa"    prefWidth="240"/>
                            <TableColumn fx:id="colCustomer" text="Zákazník"  prefWidth="200"/>
                            <TableColumn fx:id="colRooms"    text="Izby"      prefWidth="80"/>
                            <TableColumn fx:id="colArea"     text="Plocha m²" prefWidth="100"/>
                            <TableColumn fx:id="colSteps"    text="Plán (kroky)" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="12" prefWidth="320" styleClass="detail-card">
                    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

                    <Label text="Detail apartmánu" styleClass="section-title"/>

                    <Label fx:id="detailPlaceholder" styleClass="empty-hint"
                           text="Vyberte apartmán v tabuľke vľavo."
                           wrapText="true"/>

                    <VBox fx:id="detailContent" spacing="8" visible="false" managed="false">
                        <Label fx:id="detailAddress"  styleClass="detail-name"  wrapText="true"/>
                        <Label fx:id="detailCustomer" styleClass="detail-field"/>
                        <Label fx:id="detailRooms"    styleClass="detail-field"/>
                        <Label fx:id="detailNote"     styleClass="detail-note"  wrapText="true"/>

                        <Label text="Cleaning plán" styleClass="section-title"/>

                        <ListView fx:id="stepsView" prefHeight="200" styleClass="data-table"/>

                        <HBox spacing="8">
                            <TextField fx:id="newStepField" promptText="Nový krok..." styleClass="input"
                                       HBox.hgrow="ALWAYS"/>
                            <Button text="+" onAction="#onAddStep" styleClass="primary-button" minWidth="36"/>
                        </HBox>
                        <Button text="Odstrániť vybraný krok" onAction="#onRemoveStep"
                                styleClass="danger-button" maxWidth="Infinity"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Button fx:id="editApartmentButton" text="Editovať apartmán" onAction="#onEditApartment"
                            styleClass="secondary-button" maxWidth="Infinity" disable="true"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
