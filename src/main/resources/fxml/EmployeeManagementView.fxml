<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.employee.EmployeeManagementController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="Firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="Dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Cleaning Calendar" onAction="#navCalendar" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zákazníci" onAction="#navCustomers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Cleaning Plány" onAction="#navPlans" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Zamestnanci" onAction="#navEmployees" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Odhlásiť" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="16">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label text="Zamestnanci" styleClass="page-title"/>
                    <Label text="Správa upratovacieho tímu" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Pridať zamestnanca" onAction="#onAdd" styleClass="primary-button"/>
            </HBox>

            <HBox spacing="12" styleClass="filter-bar" alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Vyhľadávanie (meno, rola)" styleClass="field-label"/>
                    <TextField fx:id="searchField" promptText="napr. Anna, SUPERVISOR" styleClass="input"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Dostupnosť" styleClass="field-label"/>
                    <ComboBox fx:id="availabilityFilter" prefWidth="180" styleClass="input"/>
                </VBox>
                <VBox spacing="4" alignment="BOTTOM_RIGHT">
                    <Label fx:id="countLabel" text="Zobrazených: 0 / 0" styleClass="page-subtitle"/>
                    <HBox spacing="8">
                        <Button fx:id="editButton" text="Editovať" onAction="#onEdit" styleClass="secondary-button"/>
                        <Button fx:id="deactivateButton" text="Deaktivovať" onAction="#onDeactivate" styleClass="danger-button"/>
                    </HBox>
                </VBox>
            </HBox>

            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colName" text="Meno" prefWidth="220"/>
                    <TableColumn fx:id="colRole" text="Rola" prefWidth="140"/>
                    <TableColumn fx:id="colHours" text="Hodiny (mesiac)" prefWidth="150"/>
                    <TableColumn fx:id="colAvailability" text="Dostupnosť" prefWidth="160"/>
                    <TableColumn fx:id="colActive" text="Aktívny" prefWidth="140"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
