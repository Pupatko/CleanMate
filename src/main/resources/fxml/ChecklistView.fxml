<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.checklist.ChecklistController"
            styleClass="dashboard-root"
            prefWidth="1080" prefHeight="760">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="%role.zamestnanec" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="%nav.moj.plan" onAction="#navMySchedule" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="%nav.historia" onAction="#navHistory" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.profil" onAction="#navProfile" styleClass="nav-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="4">
                <Button text="SK" onAction="#onLangSk" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="EN" onAction="#onLangEn" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <Button text="%nav.odhlasit" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="20">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="‹ Späť" onAction="#onBack" styleClass="secondary-button"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="propertyLabel" text="—" styleClass="page-title"/>
                    <Label fx:id="metaLabel" text="—" styleClass="page-subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="8" styleClass="form-card">
                <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="%checklist.progress" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="progressLabel" text="0 / 0  (0 %)" styleClass="task-progress-label"/>
                </HBox>
                <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity" styleClass="task-progress"/>
            </VBox>

            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="form-card">
                    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                    <Label text="%checklist.steps.title" styleClass="section-title"/>
                    <ListView fx:id="checklist" VBox.vgrow="ALWAYS" styleClass="data-table"/>
                </VBox>

                <VBox spacing="10" prefWidth="460" styleClass="form-card">
                    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="%checklist.photos.title" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="addPhotoButton" text="%checklist.photos.add"
                                onAction="#onAddPhoto" styleClass="secondary-button"/>
                    </HBox>
                    <ScrollPane fx:id="photoScroll" fitToWidth="true"
                                VBox.vgrow="ALWAYS" styleClass="photo-scroll">
                        <GridPane fx:id="photoGrid" hgap="10" vgap="10">
                            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
                        </GridPane>
                    </ScrollPane>
                </VBox>
            </HBox>

            <Label fx:id="statusBanner" text="" wrapText="true"
                   styleClass="status-banner" maxWidth="Infinity"/>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="completeButton" text="%checklist.complete"
                        onAction="#onComplete" styleClass="primary-button" disable="true"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
