<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cleanmate.presentation.LoginController"
      styleClass="login-root"
      alignment="CENTER"
      spacing="14">
    <padding>
        <Insets top="40" right="48" bottom="40" left="48"/>
    </padding>

    <Label text="CleanMate" styleClass="app-title"/>
    <Label text="%login.subtitle" styleClass="app-subtitle"/>

    <VBox spacing="6" styleClass="form-group">
        <Label text="%login.username" styleClass="field-label"/>
        <TextField fx:id="usernameField" promptText="%login.username.prompt" styleClass="input"/>
    </VBox>

    <VBox spacing="6" styleClass="form-group">
        <Label text="%login.password" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input"/>
    </VBox>

    <VBox spacing="6" styleClass="form-group">
        <Label text="%login.role" styleClass="field-label"/>
        <ComboBox fx:id="roleCombo" styleClass="input" maxWidth="Infinity"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="error-label" managed="true" visible="false"/>

    <Button text="%login.submit" onAction="#onLogin" styleClass="primary-button" maxWidth="Infinity"/>

    <HBox spacing="8" alignment="CENTER">
        <Button text="SK" onAction="#onLangSk" styleClass="lang-button"/>
        <Button text="EN" onAction="#onLangEn" styleClass="lang-button"/>
    </HBox>
</VBox>
