<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.customer.CustomerManagementController"
            styleClass="dashboard-root"
            prefWidth="1180" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="%role.firma" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="%nav.dashboard" onAction="#navDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.upratovania" onAction="#navCalendar" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.zakaznici" onAction="#navCustomers" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Button text="%nav.apartmany" onAction="#navApartments" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.zamestnanci" onAction="#navEmployees" styleClass="nav-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="4">
                <Button text="SK" onAction="#onLangSk" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="EN" onAction="#onLangEn" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <Button text="%nav.odhlasit" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="20">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label text="%customers.title" styleClass="page-title"/>
                    <Label text="%customers.subtitle" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="%customers.add" onAction="#onAdd" styleClass="primary-button"/>
            </HBox>

            <HBox spacing="12" styleClass="filter-bar" alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="%customers.search.label" styleClass="field-label"/>
                    <TextField fx:id="searchField" promptText="%customers.search.prompt" styleClass="input"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="4" alignment="CENTER_RIGHT">
                    <Label fx:id="searchHintLabel" text="%customers.search.hint" styleClass="page-subtitle"/>
                </VBox>
            </HBox>

            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="colName" text="%col.customer.name" prefWidth="220"/>
                            <TableColumn fx:id="colEmail" text="%col.customer.email" prefWidth="220"/>
                            <TableColumn fx:id="colPhone" text="%col.customer.phone" prefWidth="160"/>
                            <TableColumn fx:id="colProperties" text="%col.customer.properties" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="12" prefWidth="320" styleClass="detail-card">
                    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

                    <Label text="%customers.detail.title" styleClass="section-title"/>

                    <Label fx:id="detailPlaceholder" styleClass="empty-hint"
                           text="%customers.detail.hint"
                           wrapText="true"/>

                    <Label fx:id="detailName" styleClass="detail-name" wrapText="true"/>
                    <Label fx:id="detailEmail" styleClass="detail-field"/>
                    <Label fx:id="detailPhone" styleClass="detail-field"/>
                    <Label fx:id="detailProperties" styleClass="detail-field"/>
                    <Label fx:id="detailNote" styleClass="detail-note" wrapText="true"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Button fx:id="editButton" text="%btn.edit.customer" onAction="#onEdit"
                            styleClass="secondary-button" maxWidth="Infinity"/>
                    <Button fx:id="showPropertiesButton" text="%btn.show.properties"
                            onAction="#onShowProperties" styleClass="primary-button" maxWidth="Infinity"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
