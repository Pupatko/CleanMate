<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cleanmate.presentation.invoices.InvoicesController"
            styleClass="dashboard-root"
            prefWidth="1080" prefHeight="720">

    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="24" right="16" bottom="16" left="16"/></padding>
            <Label text="CleanMate" styleClass="sidebar-brand"/>
            <Label text="%role.zakaznik" styleClass="sidebar-subtitle"/>
            <Region prefHeight="20"/>
            <Button text="%nav.prehlad.upratovani" onAction="#navPortal" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.moje.apartmany" onAction="#navProperties" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.faktury" onAction="#navInvoices" styleClass="nav-button, nav-active" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="4">
                <Button text="SK" onAction="#onLangSk" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="EN" onAction="#onLangEn" styleClass="lang-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <Button text="%nav.odhlasit" onAction="#navLogout" styleClass="nav-button, nav-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content" spacing="20">
            <padding><Insets top="28" right="32" bottom="24" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label text="%invoices.customer.title" styleClass="page-title"/>
                    <Label text="%invoices.customer.subtitle" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="downloadButton" text="%invoices.customer.download"
                        onAction="#onDownload" styleClass="primary-button"/>
            </HBox>

            <HBox spacing="16">
                <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="yearTotalLabel" text="0 €" styleClass="card-value"/>
                    <Label text="%invoices.customer.card.year" styleClass="card-label"/>
                </VBox>
                <VBox styleClass="summary-card, card-warning" HBox.hgrow="ALWAYS">
                    <Label fx:id="unpaidLabel" text="0 €" styleClass="card-value"/>
                    <Label text="%invoices.customer.card.unpaid" styleClass="card-label"/>
                </VBox>
                <VBox styleClass="summary-card, card-info" HBox.hgrow="ALWAYS">
                    <Label fx:id="countLabel" text="0" styleClass="card-value"/>
                    <Label text="%invoices.customer.card.count" styleClass="card-label"/>
                </VBox>
            </HBox>

            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colNumber"   text="%col.invoices.number"   prefWidth="130"/>
                    <TableColumn fx:id="colPeriod"   text="%col.invoices.period"   prefWidth="150"/>
                    <TableColumn fx:id="colDueDate"  text="%col.invoices.due"      prefWidth="120"/>
                    <TableColumn fx:id="colCleanings" text="%col.invoices.cleanings" prefWidth="100"/>
                    <TableColumn fx:id="colAmount"   text="%col.invoices.amount"   prefWidth="120"/>
                    <TableColumn fx:id="colStatus"   text="%col.invoices.status"   prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
